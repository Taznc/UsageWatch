{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UsageWatch",
  "version": "0.1.0",
  "identifier": "com.joshashworth.usagewatch",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "UsageWatch",
        "width": 380,
        "height": 800,
        "resizable": false,
        "maximizable": false,
        "visible": false,
        "decorations": false,
        "skipTaskbar": true,
        "alwaysOnTop": true
      },
      {
        "label": "widget",
        "title": "UsageWatch Widget",
        "url": "widget/index.html",
        "width": 380,
        "height": 300,
        "resizable": false,
        "maximizable": false,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "shadow": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' https: data:; connect-src 'self' https:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "icons/providers/claude.png",
      "icons/providers/codex.png",
      "icons/providers/cursor.png"
    ]
  }
}
