{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UsageWatch",
  "version": "0.1.0",
  "identifier": "com.joshashworth.usagewatch",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "UsageWatch",
        "width": 380,
        "height": 800,
        "resizable": false,
        "visible": false,
        "decorations": false,
        "skipTaskbar": true,
        "alwaysOnTop": true
      },
      {
        "label": "widget",
        "title": "UsageWatch Widget",
        "url": "widget/index.html",
        "width": 380,
        "height": 300,
        "resizable": true,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "skipTaskbar": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
